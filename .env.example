# 对外访问端口
APP_PORT=3000

# 凌云 API 默认值（Key 推荐在系统设置界面填写）
AI_API_URL=https://yunllm.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o

# 可选：预设管理员密码；留空则首次打开系统设置时创建
ADMIN_PASSWORD=

# 记录日期使用的时区
APP_TIMEZONE=Asia/Shanghai

# HTTPS 反向代理部署时设置为 true
COOKIE_SECURE=false

# 可选：固定的配置加密密钥；留空时系统会在数据卷自动生成
CONFIG_SECRET=

# 请求控制
AI_TIMEOUT_MS=45000
AI_JSON_MODE=true
MAX_IMAGE_BYTES=8388608
MAX_BODY_BYTES=12582912
